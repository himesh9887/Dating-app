{
  "name": "spark-social-dating",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace server\" \"npm run dev --workspace client\"",
    "dev:client": "npm run dev --workspace client",
    "dev:server": "npm run dev --workspace server",
    "dev:stack": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-dev-stack.ps1",
    "stop:stack": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/stop-dev-stack.ps1",
    "mongo:local": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-local-mongo.ps1",
    "build": "npm run build --workspace client",
    "start": "npm run start --workspace server"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
